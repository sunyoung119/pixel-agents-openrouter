# Pixel Agents Environment Variables
# Copy this file to .env and uncomment variables as needed.
# .env is gitignored and loaded automatically by the F5 launch config.

# Enable verbose debug logging for hook events (SessionStart, SessionEnd, Stop, etc.)
PIXEL_AGENTS_DEBUG=1

# ──────────────────────────────────────────────────────────────
# OpenRouter 모델 시각화 데모 (openrouter-agents/run.mjs)
# 여러 OpenRouter 모델을 에이전트로 실행해 픽셀 오피스에 캐릭터로 띄운다.
# .env 는 gitignore 되므로 실제 키를 여기(=.env)에 넣어도 커밋되지 않는다.
# ──────────────────────────────────────────────────────────────

# OpenRouter API 키 (https://openrouter.ai/keys). 실제 호출이라 필수.
# OPENROUTER_API_KEY=sk-or-v1-...

# 에이전트로 띄울 모델 목록(쉼표 구분). 각 모델 = 오피스의 캐릭터 1명.
# function calling 지원 모델 권장. 정확한 ID 는 https://openrouter.ai/models 에서 복사.
# OPENROUTER_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash,deepseek/deepseek-chat-v3.1
